# Example values to adapt the reference kOps manifests for a real AWS account.
# These are not sourced by automation in this repository; use them as the
# replacement checklist before applying the kOps manifests.

export CLUSTER_NAME=csv-processor.example.com
export KOPS_STATE_STORE=s3://replace-with-kops-state-store
export AWS_REGION=eu-west-1
export VPC_ID=vpc-xxxxxxxx
export KUBERNETES_VERSION=1.29.2

# Private and utility subnet CIDRs should match the target VPC design.
export PRIVATE_SUBNET_A_CIDR=10.0.32.0/19
export PRIVATE_SUBNET_B_CIDR=10.0.64.0/19
export UTILITY_SUBNET_A_CIDR=10.0.0.0/22
export UTILITY_SUBNET_B_CIDR=10.0.4.0/22
